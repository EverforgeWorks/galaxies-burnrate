# ==========================================================================
# Go Architecture & Backend
# ==========================================================================

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
cover.out
coverage.txt

# Dependency directories
vendor/

# Go workspace files
go.work
go.work.sum

# ==========================================================================
# Vue.js / Node.js Frontend
# ==========================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Production builds and deployment directories
dist/
dist-ssr/
build/

# Vite / Vue specific cache directories
.vite/
.nuxt/
.output/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variable files (Never commit secrets)
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================================================
# WebAssembly (Wasm) Integration
# ==========================================================================

# Compiled WebAssembly binaries generated by Go
# (Comment these out if you are tracking the compiled .wasm files in version control)
*.wasm
*.wasm.map

# ==========================================================================
# IDEs, Editors, & Operating System
# ==========================================================================

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (GoLand, WebStorm, etc.)
.idea/
*.iml

# Vim / Emacs
*~
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.Trash-*